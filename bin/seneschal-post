#!/bin/bash
# seneschal-post — post the /seneschal-review state file as a formal PR
# review under seneschal-cr[bot].
#
# Two-step UX with /seneschal-review:
#     /seneschal-review 14    # writes .claude/plans/seneschal-review-14.md
#     seneschal-post 14       # mints an installation token, posts as a review
#
# Run from inside the cloned repo (the slash command writes the state file
# relative to the repo root, and the helper reads the GitHub remote from
# the same git config).
#
# Falls back to your personal `gh` auth ONLY if --as-user is passed —
# otherwise it errors out so the bot/user separation stays explicit.
set -euo pipefail

PR="${1:-}"
AS_USER=0
shift || true
for arg in "$@"; do
  case "$arg" in
    --as-user) AS_USER=1 ;;
  esac
done

if [ -z "$PR" ]; then
  echo "usage: seneschal-post <pr-number> [--as-user]" >&2
  exit 1
fi

STATE_FILE=".claude/plans/seneschal-review-${PR}.md"
if [ ! -f "$STATE_FILE" ]; then
  echo "seneschal-post: state file not found at $STATE_FILE" >&2
  echo "  (run /seneschal-review $PR first)" >&2
  exit 1
fi

# Resolve owner/repo from the current git remote.
REMOTE_URL=$(git config --get remote.origin.url 2>/dev/null) || {
  echo "seneschal-post: not in a git repo" >&2
  exit 1
}
OWNER_REPO=$(echo "$REMOTE_URL" \
  | sed -E 's|.*github\.com[:/]([^/]+/[^/]+)|\1|; s|\.git$||')
if [[ "$OWNER_REPO" != */* ]]; then
  echo "seneschal-post: could not parse owner/repo from $REMOTE_URL" >&2
  exit 1
fi

# Determine the GitHub review event from the state file's Verdict line.
VERDICT_LINE=$(grep -m1 -E '^\*\*Verdict:\*\*' "$STATE_FILE" || echo "")
case "$VERDICT_LINE" in
  *REQUEST_CHANGES*|*"REQUEST CHANGES"*) EVENT="REQUEST_CHANGES" ;;
  *APPROVE*) EVENT="APPROVE" ;;
  *) EVENT="COMMENT" ;;
esac

if [ "$AS_USER" = "1" ]; then
  echo "seneschal-post: posting under your gh user (--as-user)"
  case "$EVENT" in
    REQUEST_CHANGES) gh pr review "$PR" --body-file "$STATE_FILE" --request-changes ;;
    APPROVE)         gh pr review "$PR" --body-file "$STATE_FILE" --approve ;;
    *)               gh pr review "$PR" --body-file "$STATE_FILE" --comment ;;
  esac
  exit 0
fi

# Pick the right Python: the OCI deploy ships a venv at ~/seneschal/venv
# with pyjwt + requests preinstalled. On local Macs the system python3
# usually has both via pyenv. Fall back to plain python3 if no venv exists.
PYTHON_BIN="python3"
if [ -x "$HOME/seneschal/venv/bin/python" ]; then
  PYTHON_BIN="$HOME/seneschal/venv/bin/python"
fi

# Mint a Seneschal installation token. Bot identity from here on.
TOKEN=$("$PYTHON_BIN" ~/seneschal/seneschal_token.py "$OWNER_REPO") || {
  echo "seneschal-post: token mint failed (App not installed on $OWNER_REPO?)" >&2
  echo "  retry under your user with: seneschal-post $PR --as-user" >&2
  exit 2
}

# Build the review payload as JSON via jq so the markdown body survives
# embedded backticks, quotes, and newlines without manual escaping. Pipe
# into `gh api --input -` which forwards stdin as the request body.
URL=$(jq -n \
  --rawfile body "$STATE_FILE" \
  --arg event "$EVENT" \
  '{body: $body, event: $event}' \
  | GH_TOKEN="$TOKEN" gh api \
      "repos/$OWNER_REPO/pulls/$PR/reviews" \
      --input - \
      --jq '.html_url')

echo "seneschal-post: posted $EVENT review as seneschal-cr[bot]"
echo "  $URL"
